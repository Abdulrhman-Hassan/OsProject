<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SchedulerGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SchedulerGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OS Scheduler"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVis" />
            <local:ZeroToDashConverter x:Key="ZeroToDash" />

            <!-- DataTemplate WITH Priority column (used for Priority-based algorithms) -->
            <DataTemplate x:Key="ProcTplWithPriority">
                <Grid Padding="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                            Opacity="0.4" CornerRadius="4"
                            Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVis}}"
                            Grid.ColumnSpan="7" Margin="-8,-4,-8,-4"/>
                    <TextBlock Grid.Column="0" Text="{Binding Name}"          FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding ArrivalTime}" />
                    <TextBlock Grid.Column="2" Text="{Binding BurstTime}" />
                    <TextBlock Grid.Column="3" Text="{Binding Priority}" />
                    <TextBlock Grid.Column="4" Text="{Binding FinishTime, Converter={StaticResource ZeroToDash}}" />
                    <TextBlock Grid.Column="5" Text="{Binding TurnaroundTime, Converter={StaticResource ZeroToDash}}" />
                    <TextBlock Grid.Column="6" Text="{Binding WaitingTime, Converter={StaticResource ZeroToDash}, ConverterParameter=AllowZero}" />
                </Grid>
            </DataTemplate>

            <!-- DataTemplate WITHOUT Priority column (used for non-priority algorithms) -->
            <DataTemplate x:Key="ProcTplNoPriority">
                <Grid Padding="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                            Opacity="0.4" CornerRadius="4"
                            Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVis}}"
                            Grid.ColumnSpan="6" Margin="-8,-4,-8,-4"/>
                    <TextBlock Grid.Column="0" Text="{Binding Name}"          FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding ArrivalTime}" />
                    <TextBlock Grid.Column="2" Text="{Binding BurstTime}" />
                    <TextBlock Grid.Column="3" Text="{Binding FinishTime, Converter={StaticResource ZeroToDash}}" />
                    <TextBlock Grid.Column="4" Text="{Binding TurnaroundTime, Converter={StaticResource ZeroToDash}}" />
                    <TextBlock Grid.Column="5" Text="{Binding WaitingTime, Converter={StaticResource ZeroToDash}, ConverterParameter=AllowZero}" />
                </Grid>
            </DataTemplate>

        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="OS Scheduler">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar for Inputs -->
            <ScrollViewer Grid.Column="0" Margin="0,0,20,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="20" Padding="0,0,15,30">

                    <!-- Add Process Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Add Process" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,5" />

                            <NumberBox x:Name="NbArrival" Header="Arrival Time" Value="0" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" ValidationMode="Disabled" />
                            <NumberBox x:Name="NbBurst" Header="Burst Time" Value="1" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" ValidationMode="Disabled" />

                            <!-- Priority input — visible only for priority-based algorithms -->
                            <NumberBox x:Name="NbPriority" Header="Priority (lower = higher priority)" Value="1" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" ValidationMode="Disabled" />

                            <Button x:Name="BtnAddProcess" Content="Add Process" Click="OnAddProcessClick" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Scheduler Settings Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Scheduler Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,5" />

                            <!-- Algorithm selector -->
                            <ComboBox x:Name="CbAlgorithm"
                                  Header="Algorithm"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnAlgorithmChanged" />

                            <!-- Tie Breaker — visible only for Priority-based algorithms -->
                            <ComboBox x:Name="CbTieBreaker"
                                  Header="Tie Breaker"
                                  HorizontalAlignment="Stretch"
                                  Visibility="Collapsed"
                                  SelectionChanged="OnTieBreakerChanged" />

                            <!-- Quantum — visible only for algorithms that need it -->
                            <NumberBox x:Name="NbQuantum" Header="Quantum" Value="2" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch" ValidationMode="Disabled" />

                            <!-- Live Mode toggle -->
                            <CheckBox x:Name="CbLiveMode" Content="Live Mode (add processes while running)" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Action Controls Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="15,15,15,25" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <Button x:Name="BtnStart" Content="Start Scheduler" Click="OnStartClick" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnPause" Grid.Column="0" Content="Pause" Click="OnPauseClick" HorizontalAlignment="Stretch" IsEnabled="False" />
                                <Button x:Name="BtnReset" Grid.Column="1" Content="Reset" Click="OnResetClick" HorizontalAlignment="Stretch" />
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Table View & Gantt Chart -->
            <Grid Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- title -->
                    <RowDefinition Height="Auto"/>
                    <!-- column headers -->
                    <RowDefinition Height="*"/>
                    <!-- table — fills available space, scrolls vertically -->
                    <RowDefinition Height="Auto"/>
                    <!-- gantt — wraps content, sits at bottom -->
                </Grid.RowDefinitions>

                <TextBlock x:Name="TbTitle" Text="Processes Table" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,10" />

                <!-- Column headers -->
                <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition x:Name="ColPriorityHeader" Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PID"        FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="Arrival"    FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="Burst"      FontWeight="Bold" />
                    <TextBlock x:Name="TbPriorityHeader" Grid.Column="3" Text="Priority" FontWeight="Bold" />
                    <TextBlock Grid.Column="4" Text="Finish"     FontWeight="Bold" />
                    <TextBlock Grid.Column="5" Text="Turnaround" FontWeight="Bold" />
                    <TextBlock Grid.Column="6" Text="Waiting"    FontWeight="Bold" />
                </Grid>

                <!--
                    Table — fills the top half of the right panel.
                    ListView has built-in vertical scrolling so it scrolls
                    automatically when there are more rows than fit.
                -->
                <ListView x:Name="LvProcesses" Grid.Row="2" Margin="0,10,0,0" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <!-- ItemTemplate is set at runtime in OnAlgorithmChanged -->
                </ListView>

                <!--
                    Gantt chart — fills the bottom half.
                    The outer Grid pins the label at the top and lets the
                    ScrollViewer take all remaining height, so it never grows
                    beyond its half and scrolls horizontally for wide charts.
                -->
                <Border Grid.Row="3"
                        Margin="0,15,0,0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- "Gantt Chart" label -->
                            <RowDefinition Height="Auto"/>
                            <!-- scrollable chart area -->
                            <RowDefinition Height="Auto"/>
                            <!-- stats bar -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                               Text="Gantt Chart"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,10" />

                        <ScrollViewer Grid.Row="1"
                                  Margin="0,0,0,10"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled">
                            <ItemsControl x:Name="IcGantt" HorizontalAlignment="Left">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Margin="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- The coloured block -->
                                            <Border Grid.Row="0" Height="40"
                                                Background="{Binding BlockColor}"
                                                BorderBrush="Black"
                                                BorderThickness="{Binding BorderThick}"
                                                CornerRadius="2">
                                                <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding ObjectColor}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold" FontSize="14" />
                                            </Border>

                                            <!-- Timeline markers -->
                                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                                <TextBlock Text="{Binding StartTime}"
                                                       HorizontalAlignment="Left"
                                                       FontSize="12" Foreground="Gray"
                                                       Visibility="{Binding ShowStartText}" />
                                                <TextBlock Text="{Binding EndTime}"
                                                       HorizontalAlignment="Right"
                                                       FontSize="12" Foreground="Gray" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- ── Stats bar ── -->
                        <Border Grid.Row="2"
                            Margin="0,15,0,0"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="15,12">
                            <StackPanel Orientation="Horizontal" Spacing="40">

                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Avg Waiting Time:"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                    <TextBlock x:Name="TbAvgWaiting"
                                           Text="—"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Avg Turnaround Time:"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                    <TextBlock x:Name="TbAvgTurnaround"
                                           Text="—"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
